# Virtual environment
.venv/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Environment variables
.env
.env.*

# Data directories (raw, normalized, snapshots contain large/generated data)
data/raw/*
!data/raw/.gitkeep
data/normalized/*
!data/normalized/.gitkeep
data/snapshots/*
!data/snapshots/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Distribution
dist/
build/
*.egg-info/
