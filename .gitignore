# Virtual environment
.venv/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Environment variables
.env
.env.*

# Data directories (raw, normalized, snapshots contain large/generated data)
data/raw/*
!data/raw/.gitkeep
data/normalized/*
!data/normalized/.gitkeep
data/snapshots/*
!data/snapshots/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Generated reports (ephemeral, timestamped)
reports/*.md

# Account runtime data (ledgers, memory, reports, data — generated each cycle)
accounts/*/ledgers/
accounts/*/memory/
accounts/*/reports/
accounts/*/data/
# Keep the directory structure
!accounts/.gitkeep
!accounts/*/.gitkeep

# Distribution
dist/
build/
*.egg-info/
